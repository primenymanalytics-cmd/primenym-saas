rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{userId} {
      // Allow users to read and write their own profile, admins can do anything
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }
    
    match /subscriptions/{userId} {
      // Allow users to read their own subscription data (written by Stripe webhooks)
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if false; // Only admin SDK (Stripe webhook) can write here
    }
    
    match /sources/{sourceId} {
      // Allow users to create sources if the userId matches their auth uid
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Allow users to read/update/delete their own sources, admins can do anything
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isAdmin();
    }
    
    match /contact_messages/{messageId} {
      // Allow anyone to submit a contact form, admins can read/update/delete
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
